# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Jupyter / IPython
.ipynb_checkpoints/

# Logs and runtime files
*.log
*.tmp
*.temp
*.pid

# OS / editor files
.DS_Store
Thumbs.db
Desktop.ini

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

# Local secrets / environment files
.env
.env.*
*.key
*.pem

# Optional: large model/audio artifacts
# If your ONNX model or audio recordings are large, consider Git LFS.
# Uncomment to avoid committing them directly:
# voices/*.onnx
# voices/*.bin
# *.wav
# *.mp3
